###############################################################################
# Golden Team Trading Services — NEO Platform
# Environment Variables Template
# Copy this file to .env and fill in ALL values before running
# Document: GT-INFRA-001 | Version: 1.0 | March 2026
###############################################################################

# =============================================================================
# DOMAIN CONFIGURATION
# Replace all yourdomain.com with your actual domain
# =============================================================================
DOMAIN_MAIN=portal.yourdomain.com
DOMAIN_ODOO=erp.yourdomain.com
DOMAIN_OPENPROJECT=pm.yourdomain.com
DOMAIN_METABASE=bi.yourdomain.com
DOMAIN_ROCKETCHAT=chat.yourdomain.com
DOMAIN_OUTLINE=wiki.yourdomain.com
DOMAIN_MINIO=files.yourdomain.com
DOMAIN_ORANGEHRM=hr.yourdomain.com

# =============================================================================
# POSTGRESQL — SUPERUSER (used only for initial setup)
# =============================================================================
POSTGRES_SUPERUSER=gtadmin
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_STRONG_PASSWORD_1

# =============================================================================
# POSTGRESQL — PER-APPLICATION DATABASE USERS
# Each application gets its own database and user (principle of least privilege)
# =============================================================================

# NEO Platform database
NEO_DB_NAME=neo_platform
NEO_DB_USER=neo_app
NEO_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_2

# Odoo ERP database
ODOO_DB_NAME=odoo_production
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_3

# OrangeHRM database
ORANGEHRM_DB_NAME=orangehrm
ORANGEHRM_DB_USER=orangehrm
ORANGEHRM_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_4

# OpenProject database
OPENPROJECT_DB_NAME=openproject
OPENPROJECT_DB_USER=openproject
OPENPROJECT_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_5

# Metabase database
METABASE_DB_NAME=metabase
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_6

# Outline database
OUTLINE_DB_NAME=outline
OUTLINE_DB_USER=outline
OUTLINE_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_7

# =============================================================================
# REDIS
# =============================================================================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_8

# =============================================================================
# MINIO OBJECT STORAGE
# =============================================================================
MINIO_ROOT_USER=gtminio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_9

# =============================================================================
# OUTLINE KNOWLEDGE BASE
# Generate with: openssl rand -hex 32
# =============================================================================
OUTLINE_SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
OUTLINE_UTILS_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32

# =============================================================================
# NEO AI CORE — API KEYS
# =============================================================================
MANUS_API_KEY=your_manus_api_key_here
MANUS_API_URL=https://api.manus.im/v1
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# =============================================================================
# NEO APPLICATION
# =============================================================================
NEO_JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_64
NEO_SESSION_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32
NEO_PORT=4000
NODE_ENV=production

# =============================================================================
# ODOO CONFIGURATION
# =============================================================================
ODOO_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_10
ODOO_MASTER_PASSWORD=CHANGE_ME_STRONG_PASSWORD_11

# =============================================================================
# EMAIL / SMTP (for notifications and approvals)
# =============================================================================
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=NEO Platform <notifications@yourdomain.com>

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_S3_BUCKET=gt-neo-backups
BACKUP_S3_REGION=me-south-1
BACKUP_AWS_ACCESS_KEY=your_backup_s3_access_key
BACKUP_AWS_SECRET_KEY=your_backup_s3_secret_key

# =============================================================================
# TIMEZONE
# =============================================================================
TZ=Asia/Riyadh
